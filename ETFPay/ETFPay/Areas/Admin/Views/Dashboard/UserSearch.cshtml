@model ETFPay.Areas.Admin.Controllers.DashboardController.UserSearchViewModel
@{
    ViewData["Title"] = "User Search";
}

<style>
    .user-search-page {
        padding: 24px 8px 48px;
    }

    .search-toolbar {
        display: flex;
        gap: 32px;
        margin-bottom: 2rem;
        align-items: flex-start;
    }

    .search-toolbar-section {
        flex: 1;
        min-width: 0;
    }

    .search-section-title {
        font-size: 1.25rem;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        color: #111;
    }

    .admin-page {
        display: flex;
        gap: 48px;
        align-items: flex-start;
    }

    @@media (max-width: 768px) {
        .search-toolbar,
        .admin-page {
            flex-direction: column;
            gap: 24px;
        }

        .detail-row {
            flex-direction: column;
            align-items: stretch;
        }

        .detail-label {
            min-width: 0;
        }
    }

    .admin-col {
        flex: 1;
        min-width: 0;
    }

    .admin-title {
        font-size: 1.75rem;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
        color: #111;
    }

    .admin-list-head {
        display: flex;
        justify-content: space-between;
        font-weight: 600;
        color: #666;
        margin-bottom: 0.75rem;
        padding: 0 0.25rem;
    }

    .admin-list {
        max-height: 520px;
        overflow-y: auto;
        padding-right: 4px;
    }

    .admin-list-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #ececec;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 10px;
        text-decoration: none;
        color: #333;
        transition: background 0.2s ease;
        cursor: pointer;
    }

    .admin-list-item:hover {
        background: #e2e2e2;
        color: #333;
    }

    .admin-list-item.active {
        background: #1f6b60;
        color: #fff;
    }

    .admin-list-item.active span:last-child {
        color: #e8f5f2;
    }

    .admin-form .form-control,
    .admin-form .form-select {
        border-radius: 10px;
        border: 1px solid #ccc;
        padding: 12px 14px;
        margin-bottom: 12px;
        font-size: 0.95rem;
        width: 100%;
    }

    .admin-form .form-control::placeholder {
        color: #999;
    }

    .admin-btn {
        background: #1f6b60;
        color: #fff;
        border: 3px solid #fff;
        border-radius: 10px;
        padding: 14px 48px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    }

    .admin-btn:hover {
        background: #164d43;
        color: #fff;
        border-color: #fff;
    }

    .detail-header {
        background: #1f6b60;
        color: #fff;
        border-radius: 10px;
        padding: 16px 20px;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
        font-size: 1.1rem;
    }

    .detail-row {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 12px;
    }

    .detail-label {
        min-width: 140px;
        font-weight: 600;
        color: #333;
    }

    .detail-value {
        flex: 1;
        border-radius: 10px;
        border: 1px solid #ccc;
        padding: 12px 14px;
        background: #f5f5f5;
        color: #333;
        font-size: 0.95rem;
    }

    .admin-alert {
        border-radius: 10px;
        margin-bottom: 1rem;
    }

    .left-actions {
        margin-top: 1rem;
    }
</style>

<div class="user-search-page">
    @if (TempData["Success"] is string successMessage)
    {
        <div class="alert alert-success admin-alert">@successMessage</div>
    }
    @if (TempData["Error"] is string errorMessage)
    {
        <div class="alert alert-danger admin-alert">@errorMessage</div>
    }

    <div class="search-toolbar">
        <div class="search-toolbar-section">
            <h3 class="search-section-title">Search</h3>
            <form class="admin-form" method="get" asp-area="Admin" asp-controller="Dashboard" asp-action="UserSearch">
                <input type="hidden" name="filter" value="@Model.Filter" />
                <input type="hidden" name="sort" value="@Model.Sort" />
                <input type="hidden" name="sortDir" value="@Model.SortDirection" />
                <input type="hidden" name="id" value="@Model.OdabraniId" />
                <input type="text" name="q" value="@Model.Pretraga" class="form-control" placeholder="Enter client name" />
                <button type="submit" class="admin-btn">Search</button>
            </form>
        </div>

        <div class="search-toolbar-section">
            <h3 class="search-section-title">Filter</h3>
            <form class="admin-form" method="get" asp-area="Admin" asp-controller="Dashboard" asp-action="UserSearch">
                <input type="hidden" name="q" value="@Model.Pretraga" />
                <input type="hidden" name="sort" value="@Model.Sort" />
                <input type="hidden" name="sortDir" value="@Model.SortDirection" />
                <input type="hidden" name="id" value="@Model.OdabraniId" />
                <select name="filter" class="form-select">
                    <option value="">Select filter</option>
                    <option value="aktivan" selected="@(Model.Filter == "aktivan" ? "selected" : null)">Active account</option>
                    <option value="neaktivan" selected="@(Model.Filter == "neaktivan" ? "selected" : null)">Inactive account</option>
                    <option value="pozitivno-stanje" selected="@(Model.Filter == "pozitivno-stanje" ? "selected" : null)">Balance greater than 0</option>
                    <option value="nulto-stanje" selected="@(Model.Filter == "nulto-stanje" ? "selected" : null)">Balance 0</option>
                </select>
                <button type="submit" class="admin-btn">Apply filter</button>
            </form>
        </div>

        <div class="search-toolbar-section">
            <h3 class="search-section-title">Sort</h3>
            <form class="admin-form" method="get" asp-area="Admin" asp-controller="Dashboard" asp-action="UserSearch">
                <input type="hidden" name="q" value="@Model.Pretraga" />
                <input type="hidden" name="filter" value="@Model.Filter" />
                <input type="hidden" name="id" value="@Model.OdabraniId" />
                <select name="sort" class="form-select">
                    <option value="ime" selected="@(Model.Sort == "ime" ? "selected" : null)">First name</option>
                    <option value="prezime" selected="@(Model.Sort == "prezime" ? "selected" : null)">Last name</option>
                    <option value="stanje" selected="@(Model.Sort == "stanje" ? "selected" : null)">Account balance</option>
                </select>
                <select name="sortDir" class="form-select">
                    <option value="asc" selected="@(Model.SortDirection == "asc" ? "selected" : null)">Ascending</option>
                    <option value="desc" selected="@(Model.SortDirection == "desc" ? "selected" : null)">Descending</option>
                </select>
                <button type="submit" class="admin-btn">Sort</button>
            </form>
        </div>
    </div>

    <div class="admin-page">
        <div class="admin-col">
            <h2 class="admin-title">Clients</h2>

            <div class="admin-list-head">
                <span>Client</span>
                <span>Account number</span>
            </div>

            <div class="admin-list">
                @if (Model.Klijenti.Any())
                {
                    @foreach (var k in Model.Klijenti)
                    {
                        <a class="admin-list-item @(k.Id == Model.OdabraniId ? "active" : "")"
                           asp-area="Admin"
                           asp-controller="Dashboard"
                           asp-action="UserSearch"
                           asp-route-q="@Model.Pretraga"
                           asp-route-filter="@Model.Filter"
                           asp-route-sort="@Model.Sort"
                           asp-route-sortDir="@Model.SortDirection"
                           asp-route-id="@k.Id">
                            <span>@k.PunoIme</span>
                            <span>@k.BrojRacuna</span>
                        </a>
                    }
                }
                else
                {
                    <div class="text-muted py-3">No clients to display.</div>
                }
            </div>

            @if (Model.Odabrani != null)
            {
                <div class="left-actions">
                    <form asp-area="Admin" asp-controller="Dashboard" asp-action="ObrisiKlijenta" method="post"
                          onsubmit="return confirm('Are you sure you want to delete this client?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Odabrani.Id" />
                        <input type="hidden" name="q" value="@Model.Pretraga" />
                        <input type="hidden" name="filter" value="@Model.Filter" />
                        <input type="hidden" name="sort" value="@Model.Sort" />
                        <input type="hidden" name="sortDir" value="@Model.SortDirection" />
                        <button type="submit" class="admin-btn">Delete</button>
                    </form>
                </div>
            }
        </div>

        <div class="admin-col">
            @if (Model.Odabrani != null)
            {
                <div class="detail-header">@Model.Odabrani.ImePrezime</div>

                <div class="detail-row">
                    <span class="detail-label">Email</span>
                    <div class="detail-value">@Model.Odabrani.Email</div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Phone number</span>
                    <div class="detail-value">@(string.IsNullOrWhiteSpace(Model.Odabrani.BrojTelefona) ? "—" : Model.Odabrani.BrojTelefona)</div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">National ID</span>
                    <div class="detail-value">@Model.Odabrani.Jmbg</div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Date of birth</span>
                    <div class="detail-value">@Model.Odabrani.DatumRodjenja.ToString("MM/dd/yyyy")</div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Account number</span>
                    <div class="detail-value">@Model.Odabrani.BrojRacuna</div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">IBAN</span>
                    <div class="detail-value">@Model.Odabrani.Iban</div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Balance</span>
                    <div class="detail-value">@Model.Odabrani.Stanje.ToString("N2")</div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Account status</span>
                    <div class="detail-value">@(Model.Odabrani.Aktivan ? "Active" : "Inactive")</div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Created on</span>
                    <div class="detail-value">@(Model.Odabrani.DatumKreiranjaRacuna?.ToString("MM/dd/yyyy") ?? "—")</div>
                </div>
            }
            else
            {
                <h2 class="admin-title">Client details</h2>
                <p class="text-muted">Select a client from the list to view their details.</p>
            }
        </div>
    </div>
</div>
