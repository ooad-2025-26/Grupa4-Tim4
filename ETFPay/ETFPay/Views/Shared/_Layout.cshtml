@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ETFPay</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ETFPay.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" aria-label="ETFPay home">
                    <picture>
                        <source srcset="~/images/logo.png" type="image/png" />
                        <img src="~/images/logo.svg" alt="ETFPay" style="height:48px; margin-right:0.5rem;" />
                    </picture>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Administration</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">User Search</a>
                            </li>
                        }
                        @if (User.IsInRole("Uposlenik"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Osoba" asp-action="ZahtjeviZaRacun">Zahtjevi za Račun</a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Client") && ViewBag.RacunAktivan as bool? == true)
                        {
                            <ul class="navbar-nav me-3 gap-2">
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "Subscriptions" ? "text-primary fw-bold" : "text-dark")"
                                       asp-controller="Subscriptions" asp-action="Index">Subscriptions</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "Templates" ? "text-primary fw-bold" : "text-dark")"
                                       asp-controller="Templates" asp-action="Index">Templates</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "History" ? "text-primary fw-bold" : "text-dark")"
                                       asp-controller="History" asp-action="Index">History</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "Currencies" ? "text-primary fw-bold" : "text-dark")"
                                       asp-controller="Currencies" asp-action="Index">Currencies</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(currentController == "Payment" ? "text-primary fw-bold" : "text-dark")"
                                       asp-controller="Payment" asp-action="Index">Payment</a>
                                </li>
                            </ul>
                        }

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                &copy; 2026 - ETFPay - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>

            @if (User.Identity.IsAuthenticated)
            {
                <div class="small">
                    <span class="badge bg-secondary">
                        Role: @string.Join(", ", User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))
                    </span>
                </div>
            }
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)</body>
</html>