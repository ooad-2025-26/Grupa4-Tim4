@{
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    var isHome = string.IsNullOrEmpty(currentArea) && currentController == "Home" && currentAction == "Index";
    var isPrivacy = string.IsNullOrEmpty(currentArea) && currentController == "Home" && currentAction == "Privacy";
    var isZahtjevi = currentController == "Osoba" && currentAction == "ZahtjeviZaRacun";
    var isAdministration = currentArea == "Admin" && currentController == "Dashboard" && currentAction == "Index";
    var isUserSearch = currentArea == "Admin" && currentController == "Dashboard" && currentAction == "UserSearch";
    var isPretplate = currentController == "Predlozak" && (currentAction == "PretplataView" || currentAction == "DodavanjePretplate");
    var isPredlosci = currentController == "Predlozak" && (currentAction == "PredlozakView" || currentAction == "DodavanjePredlozaka");
    var isHistory = currentController == "Transakcija" && currentAction == "MojeTransakcije";
    var isCurrencies = currentController == "Kurs";
    var isPayment = currentController == "Transakcija" && currentAction == "Transakcija";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ETFPay</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ETFPay.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" aria-label="ETFPay home">
                    <picture>
                        <source srcset="~/images/logo.png" type="image/png" />
                        <img src="~/images/logo.svg" alt="ETFPay" style="height:48px; margin-right:0.5rem;" />
                    </picture>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @(isHome ? "nav-link-active" : "text-dark")" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isPrivacy ? "nav-link-active" : "text-dark")" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        @if (User.IsInRole("Uposlenik"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(isZahtjevi ? "nav-link-active" : "text-dark")" asp-controller="Osoba" asp-action="ZahtjeviZaRacun">Zahtjevi za Račun</a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.IsInRole("Admin"))
                        {
                            <ul class="navbar-nav me-3 gap-2">
                                <li class="nav-item">
                                    <a class="nav-link @(isAdministration ? "nav-link-active" : "text-dark")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Administration</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(isUserSearch ? "nav-link-active" : "text-dark")" asp-area="Admin" asp-controller="Dashboard" asp-action="UserSearch">User Search</a>
                                </li>
                            </ul>
                        }
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Client") && ViewBag.RacunAktivan as bool? == true)
                        {
                            <ul class="navbar-nav me-3 gap-2">
                                <li class="nav-item">
                                    <a class="nav-link @(isPretplate ? "nav-link-active" : "text-dark")"
                                       asp-controller="Predlozak" asp-action="PretplataView">Subscriptions</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(isPredlosci ? "nav-link-active" : "text-dark")"
                                       asp-controller="Predlozak" asp-action="PredlozakView">Templates</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(isHistory ? "nav-link-active" : "text-dark")"
                                       asp-controller="Transakcija" asp-action="MojeTransakcije">History</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(isCurrencies ? "nav-link-active" : "text-dark")"
                                       asp-controller="Kurs" asp-action="Index">Currencies</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(isPayment ? "nav-link-active" : "text-dark")"
                                       asp-controller="Transakcija"
                                       asp-action="Transakcija">
                                        Payment
                                    </a>
                                </li>
                            </ul>
                        }

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)</body>
</html>