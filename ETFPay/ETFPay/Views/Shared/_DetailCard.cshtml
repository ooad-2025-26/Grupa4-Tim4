@model ETFPay.Models.Predlozak

@{
    var headerText = ViewBag.HeaderText ?? "DETALJI";
}

<div style="border-radius: 8px; overflow: hidden;">
    <div style="background-color: #2d8a6f; color: white; padding: 20px; border-radius: 8px 8px 0 0;">
        <h4 style="font-weight: 700; margin: 0;">@headerText</h4>
    </div>

    <div style="background-color: #f8f9fa; padding: 20px; border-radius: 0 0 8px 8px;">
        <div class="mb-3" style="display: flex; justify-content: space-between;">
            <strong>Broj racuna</strong>
            <div style="font-size: 18px;">@Model.BrojRacuna</div>
        </div>

        <hr>

        <div class="mb-3" style="display: flex; justify-content: space-between;">
            <strong>Iznos</strong>
            <div style="font-size: 18px;">@Model.Iznos.ToString("F2") $</div>
        </div>

        <hr>

        <div class="mb-3" style="display: flex; justify-content: space-between;">
            <strong>Svrha uplate</strong>
            <div style="font-size: 18px;">@Model.SvrhaUplate</div>
        </div>

        <hr>

        <div class="mb-3" style="display: flex; justify-content: space-between;">
            <strong>Datum transakcije</strong>
            <div style="font-size: 18px;">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        </div>
    </div>
</div>
