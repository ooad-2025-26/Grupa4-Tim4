@model ETFPay.Models.Racun
@{
    ViewData["Title"] = "Klijent Panel";
    var racunAktivan = ViewBag.RacunAktivan as bool? == true;
    var racun = ViewBag.Racun as ETFPay.Models.Racun;
    var transakcije = ViewBag.ZadnjeTransakcije as List<ETFPay.Models.Transakcija> ?? new();
}

<div class="hero">
    <div class="container">
        @if (!racunAktivan)
        {
            <div class="conversion mx-auto text-center">
                <h1>Račun nije aktiviran</h1>
                <div class="divider"></div>
                <p class="mb-0">Morate otići u poslovnicu radi aktivacije računa.</p>
            </div>
        }
        else if (racun != null)
        {
            <div class="d-flex flex-column align-items-center">
                <div class="conversion mx-auto p-4" style="max-width: 450px; background: linear-gradient(135deg, #1F6B60 0%, #15524A 100%); color: #fff;">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold fs-5">ETFPAY CARD</span>
                        <div style="width:40px;height:30px;background:#ffc107;border-radius:4px;opacity:0.8;"></div>
                    </div>

                    <div class="mb-4">
                        <small class="d-block text-uppercase opacity-75" style="font-size:0.75rem;">Broj računa</small>
                        <span class="fs-4 fw-semibold" style="letter-spacing:2px;">@racun.brojRacuna</span>
                    </div>

                    <div class="mb-4">
                        <small class="d-block text-uppercase opacity-75" style="font-size:0.75rem;">Stanje računa</small>
                        <span class="fs-2 fw-bold">@(decimal.Parse(racun.Stanje).ToString("N2")) KM</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-end">
                        <div>
                            <small class="d-block text-uppercase opacity-75" style="font-size:0.65rem;">Vlasnik računa</small>
                            <span class="fw-semibold text-uppercase">@User.Identity!.Name</span>
                        </div>
                        <div class="text-end">
                            <small class="d-block text-uppercase opacity-75" style="font-size:0.65rem;">Kreiran (MM/YY)</small>
                            <span class="fw-semibold">@racun.DatumKreiranja.ToString("MM/yy")</span>
                        </div>
                    </div>
                </div>

                <div class="rates mx-auto mt-4" style="max-width:450px;">
                    <div class="rate-row fw-bold" style="pointer-events:none;">
                        <span class="code"></span>
                        <span class="name">Zadnje transakcije</span>
                        <span class="value"></span>
                    </div>

                    @if (transakcije.Any())
                    {
                        @foreach (var t in transakcije)
                        {
                            var jeUlazna = t.Primaoc == racun.Id;
                            <div class="rate-row" style="pointer-events:none;">
                                <span class="code"></span>
                                <span class="name">@(jeUlazna ? "Uplata" : "Isplata")</span>
                                <span class="value @(jeUlazna ? "text-success" : "text-danger")">
                                    @(jeUlazna ? "+" : "-")@t.Iznos.ToString("N2") KM
                                </span>
                            </div>
                            <small class="text-muted d-block ps-2 pb-2">@t.VrijemeTransakcije.ToString("dd.MM.yyyy HH:mm")</small>
                        }
                    }
                    else
                    {
                        <p class="text-muted mt-3 mb-0">Nema transakcija za prikazati.</p>
                    }
                </div>
            </div>
        }
    </div>
</div>
