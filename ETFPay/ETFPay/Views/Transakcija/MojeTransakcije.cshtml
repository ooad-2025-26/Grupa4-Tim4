@model ETFPay.Models.TransakcijeViewModel
@{
    ViewData["Title"] = "History";
    var odabrana = Model.Odabrana;
}

<style>
    .history-rates {
        max-width: 560px;
    }

    .history-rates .rate-row {
        min-height: 3.5rem;
        grid-template-columns: minmax(10.5rem, 1fr) 9rem;
        border-radius: 12px;
    }

    .history-rates .rate-row .code {
        display: none;
    }

    .history-rates .rate-row .name {
        white-space: nowrap;
        padding-right: 0.75rem;
    }

    .history-rates .rate-row .value {
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }

    .history-rates .iznos-ulaz {
        color: #1F6B60;
        font-weight: 700;
    }

    .history-rates .iznos-izlaz {
        color: #c0392b;
        font-weight: 700;
    }

    .history-rates .rate-row.active .iznos-ulaz {
        color: #b8f5dc;
    }

    .history-rates .rate-row.active .iznos-izlaz {
        color: #ffc9c9;
    }

    .history-detail .iznos-ulaz {
        color: #1F6B60;
    }

    .history-detail .iznos-izlaz {
        color: #c0392b;
    }

    .history-layout {
        gap: 40px;
    }
</style>

<div class="hero">
    <div class="container">
        <h1>TRANSACTION HISTORY</h1>
        <div class="divider"></div>

        <div class="row history-layout justify-content-center">
            <div class="col-lg-5">
                <div class="rates mx-auto history-rates">
                    <div class="rate-row fw-bold" style="pointer-events:none">
                        <span class="code"></span>
                        <span class="name">Transactions</span>
                        <span class="value">Amount</span>
                    </div>

                    @if (!Model.Transakcije.Any())
                    {
                        <p class="text-muted mt-3">You have no transactions.</p>
                    }

                    @foreach (var t in Model.Transakcije)
                    {
                        var plus = t.Primaoc == Model.RacunIdKorisnika;
                        var imeProtivnika = Model.ImeProtivnikaPoTransakciji.GetValueOrDefault(t.Id, "—");
                        <a asp-action="MojeTransakcije" asp-route-id="@t.Id"
                           class="rate-row text-decoration-none @(odabrana?.Id == t.Id ? "active" : "")">
                            <span class="code"></span>
                            <span class="name">@imeProtivnika</span>
                            <span class="value @(plus ? "iznos-ulaz" : "iznos-izlaz")">@(plus ? "+" : "-")@t.Iznos.ToString("N2") BAM</span>
                        </a>
                    }
                </div>
            </div>

            <div class="col-lg-5">
                @if (odabrana != null)
                {
                    var plus = odabrana.Primaoc == Model.RacunIdKorisnika;
                    var imeOdabrane = Model.ImeProtivnikaPoTransakciji.GetValueOrDefault(odabrana.Id, "—");
                    <div class="conversion mx-auto history-detail">
                        <div class="rate-row active mb-3" style="pointer-events:none">
                            <span class="code"></span>
                            <span class="name">@imeOdabrane.ToUpper()</span>
                            <span class="value"></span>
                        </div>
                        <div class="d-flex justify-content-between py-2 border-bottom">
                            <span>Account number</span>
                            <span class="fw-semibold">@(string.IsNullOrEmpty(Model.BrojRacunaDrugaStrana) ? "—" : Model.BrojRacunaDrugaStrana)</span>
                        </div>
                        <div class="d-flex justify-content-between py-2 border-bottom">
                            <span>Amount</span>
                            <span class="fw-semibold @(plus ? "iznos-ulaz" : "iznos-izlaz")">@(plus ? "+" : "-")@odabrana.Iznos.ToString("N2") BAM</span>
                        </div>
                        <div class="d-flex justify-content-between py-2 border-bottom">
                            <span>Payment purpose</span>
                            <span class="fw-semibold">@(string.IsNullOrEmpty(odabrana.SvrhaUplate) ? "-" : odabrana.SvrhaUplate)</span>
                        </div>
                        <div class="d-flex justify-content-between py-2">
                            <span>Transaction date</span>
                            <span class="fw-semibold">@odabrana.VrijemeTransakcije.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="conversion mx-auto">
                        <p class="text-muted mb-0">Select a transaction.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>