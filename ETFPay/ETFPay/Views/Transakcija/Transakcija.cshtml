@{
    ViewData["Title"] = "Payments";
}

<div class="container mt-4">
    <div class="row">

        <!-- Left Side -->
        <div class="col-md-4">
            <h2 class="fw-bold text-center mb-4">PAYMENTS</h2>

            <button id="newPaymentBtn"
                    class="btn w-100 mb-4 text-white"
                    style="background-color:#1F6B60; border-color:#1F6B60;">
                NEW PAYMENT
            </button>

            <div class="card">
                <div class="card-header text-white fw-bold"
                     style="background-color:#1F6B60;">
                    Templates
                </div>

                <div class="list-group list-group-flush">
                    <button class="list-group-item list-group-item-action template-item"
                            data-name="Muji"
                            data-purpose="Personal Transfer"
                            data-account="123456789">
                        Muji
                    </button>

                    <button class="list-group-item list-group-item-action template-item"
                            data-name="Selma"
                            data-purpose="Personal Transfer"
                            data-account="987654321">
                        Selma
                    </button>

                    <button class="list-group-item list-group-item-action template-item"
                            data-name="Kerim"
                            data-purpose="Personal Transfer"
                            data-account="111222333">
                        Kerim
                    </button>
                </div>
            </div>
        </div>

        <!-- Right Side -->
        <div class="col-md-8">
            <h2 class="fw-bold text-center mb-4">PAYMENT DETAILS</h2>

            <form id="paymentForm" asp-action="CreateTransaction" asp-controller="Transakcija" method="post">

             
                    <div class="row">
                    <div class="col-md-6 mb-3">
                        <input id="recipientName"
                           name="RecipientName"
                           class="form-control"
                           placeholder="Recipient Name"
                           minlength="2"
                           maxlength="100"
                           pattern="[A-Za-zÀ-ž\s]+"
                           required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <input id="accountNumber"
                               name="RecipientAccountNumber"
                               class="form-control"
                               placeholder="Account Number / IBAN"
                               required
                               pattern="(\d{16}|BA\d{18})" />
                    </div>

                           <div class="col-md-6 mb-3">
                    <input id="purpose"
                           name="Purpose"
                           class="form-control"
                           placeholder="Purpose"
                           minlength="3"
                           maxlength="200"
                           required />
                            </div>
                        <div class="col-md-6 mb-3">
                            <input id="city"
                                   name="City"
                                   class="form-control"
                                   placeholder="City" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <input id="address"
                                   name="Address"
                                   class="form-control"
                                   placeholder="Address" />
                        </div>
                    <div class="col-md-6 mb-3">
                    <input id="amount"
                           name="Amount"
                           type="number"
                           step="0.01"
                           min="0.01"
                           max="1000000"
                           class="form-control"
                           placeholder="Amount"
                           required />
                    </div>
            </div>

                <div class="text-center mt-3">
                    <button type="button"
                            id="saveTemplateBtn"
                            class="btn me-2 text-white"
                            style="background-color:#1F6B60; border-color:#1F6B60;">
                        SAVE TEMPLATE
                    </button>

                    <button type="submit"
                            class="btn text-white"
                            style="background-color:#1F6B60;">
                        PAY
                    </button>

                    <div id="result"></div>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>

        const templateButtons =
            document.querySelectorAll('.template-item');

        templateButtons.forEach(btn => {
            btn.addEventListener('click', function () {

                document.getElementById('recipientName').value =
                    this.dataset.name;

                document.getElementById('purpose').value =
                    this.dataset.purpose;

                document.getElementById('accountNumber').value =
                    this.dataset.account;

                // Kod template-a korisnik samo unosi iznos
                document.getElementById('amount').focus();
            });
        });

        document.getElementById('newPaymentBtn')
            .addEventListener('click', function () {
                document.getElementById('paymentForm').reset();
            });

        document.getElementById("paymentForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const formData = new FormData(this);
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                formData.append("__RequestVerificationToken", token.value);
            }

            const response = await fetch("/Transakcija/CreateTransaction", {
                method: "POST",
                body: formData
            });

            const result = await response.json();
            document.getElementById("result").innerText =
                response.ok ? result.message : (result.title ?? "Error");
        });

    </script>
}