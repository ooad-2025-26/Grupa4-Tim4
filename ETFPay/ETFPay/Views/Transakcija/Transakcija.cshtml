@model IEnumerable<ETFPay.Models.Predlozak>

@{
    ViewData["Title"] = "Payments";
}

<div class="container mt-4">
    <div class="row">

        <div class="col-md-4">
            <h2 class="fw-bold text-center mb-4">PAYMENTS</h2>

            <button id="newPaymentBtn"
                    class="btn w-100 mb-4 text-white"
                    style="background-color:#1F6B60; border-color:#1F6B60;">
                NEW PAYMENT
            </button>

            <div class="card">
                <div class="card-header text-white fw-bold"
                     style="background-color:#1F6B60;">
                    Templates
                </div>

                <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">

                    @if (Model != null && Model.Any())
                    {
                        foreach (var template in Model)
                        {
                            <button class="list-group-item list-group-item-action template-item"
                                    data-name="@template.Primaoc"
                                    data-purpose="@template.SvrhaUplate"
                                    data-account="@template.BrojRacuna"
                                    data-city="@template.Grad"
                                    data-address="@template.Adresa">
                                @template.Naziv
                            </button>
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-muted text-center py-3">
                            No templates found
                        </div>
                    }

                </div>
            </div>
        </div>

        <div class="col-md-8">
            <h2 class="fw-bold text-center mb-4">PAYMENT DETAILS</h2>

            <form id="paymentForm" asp-action="CreateTransaction" asp-controller="Transakcija" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <input id="recipientName"
                               name="RecipientName"
                               class="form-control"
                               placeholder="Recipient Name"
                               minlength="2"
                               maxlength="100"
                               pattern="[A-Za-zÀ-ž\s]+"
                               required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <input id="accountNumber"
                               name="RecipientAccountNumber"
                               class="form-control"
                               placeholder="Account Number / IBAN"
                               required
                               pattern="(\d{16}|BA\d{18})" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <input id="purpose"
                               name="Purpose"
                               class="form-control"
                               placeholder="Purpose"
                               minlength="3"
                               maxlength="200"
                               required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <input id="city"
                               name="City"
                               class="form-control"
                               placeholder="City" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <input id="address"
                               name="Address"
                               class="form-control"
                               placeholder="Address" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <input id="amount"
                               name="Amount"
                               type="number"
                               step="0.01"
                               min="0.01"
                               max="1000000"
                               class="form-control"
                               placeholder="Amount"
                               required />
                    </div>
                </div>

                <div class="text-center mt-3">
                    <button type="button"
                            id="saveTemplateBtn"
                            class="btn me-2 text-white"
                            style="background-color:#1F6B60; border-color:#1F6B60;">
                        SAVE TEMPLATE
                    </button>

                    <button type="submit"
                            class="btn text-white"
                            style="background-color:#1F6B60;">
                        PAY
                    </button>

                    <div id="result" class="mt-3 fw-bold"></div>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // 1. Klik na šablon puni desnu stranu podacima
        const templateButtons = document.querySelectorAll('.template-item');

        templateButtons.forEach(btn => {
            btn.addEventListener('click', function () {
                document.getElementById('recipientName').value = this.dataset.name || '';
                document.getElementById('purpose').value = this.dataset.purpose || '';
                document.getElementById('accountNumber').value = this.dataset.account || '';
                document.getElementById('city').value = this.dataset.city || '';
                document.getElementById('address').value = this.dataset.address || '';

                const amountInput = document.getElementById('amount');
                amountInput.value = '';
                amountInput.focus();
            });
        });

        // 2. Klik na NEW PAYMENT čisti formu
        document.getElementById('newPaymentBtn').addEventListener('click', function () {
            document.getElementById('paymentForm').reset();
            document.getElementById('result').innerText = "";
            document.getElementById('recipientName').focus();
        });

       
        // NOVO: LOGIKA ZA SPASAVANJE PREDLOŠKA (SAVE TEMPLATE)
   
        document.getElementById('saveTemplateBtn').addEventListener('click', async function () {
            const resultDiv = document.getElementById("result");

            // Pokupimo podatke iz input polja
            const primaoc = document.getElementById('recipientName').value.trim();
            const brojRacuna = document.getElementById('accountNumber').value.trim();
            const svrha = document.getElementById('purpose').value.trim();
            const grad = document.getElementById('city').value.trim();
            const adresa = document.getElementById('address').value.trim();

            // Osnovna validacija: Ne dozvoljavamo spasavanje ako su glavna polja prazna
            if (!primaoc || !brojRacuna || !svrha) {
                resultDiv.innerText = "Molimo popunite Ime, Račun i Svrhu prije spasavanja predloška!";
                resultDiv.style.color = "red";
                return;
            }

            // Kreiramo objekat koji šaljemo na backend (nazivi moraju odgovarati C# akciji)
            const templateData = {
                Primaoc: primaoc,
                BrojRacuna: brojRacuna,
                SvrhaUplate: svrha,
                Grad: grad,
                Adresa: adresa,
                Naziv: "Predložak: " + primaoc // Automatski generišemo naziv predloška
            };

            resultDiv.innerText = "Spasavam predložak...";
            resultDiv.style.color = "orange";

             
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            const headers = {
                'Content-Type': 'application/json'
            };
            if (tokenInput) {
                headers['RequestVerificationToken'] = tokenInput.value;
            }

            try {
                // Šaljemo podatke na kontroler 'Predlozak' i akciju 'SaveTemplate'
                const response = await fetch("/Predlozak/SaveTemplate", {
                    method: "POST",
                    headers: headers,
                    body: JSON.stringify(templateData)
                });

                if (response.ok) {
                    resultDiv.innerText = "Predložak uspješno spasen u bazu! Osvježite stranicu da se pojavi u listi.";
                    resultDiv.style.color = "green";
                } else {
                    const errorText = await response.text();
                    resultDiv.innerText = "Greška pri spasavanju: " + errorText;
                    resultDiv.style.color = "red";
                }
            } catch (error) {
                resultDiv.innerText = "Greška u komunikaciji sa serverom.";
                resultDiv.style.color = "red";
            }
        });

        // 4. AJAX slanje uplate (PAY dugme)
        document.getElementById("paymentForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const formData = new FormData(this);
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                formData.append("__RequestVerificationToken", token.value);
            }

            const resultDiv = document.getElementById("result");
            resultDiv.innerText = "Processing...";
            resultDiv.style.color = "orange";

            try {
                const response = await fetch("/Transakcija/CreateTransaction", {
                    method: "POST",
                    body: formData
                });

                const result = await response.json();

                if (response.ok) {
                    resultDiv.innerText = result.message || "Success!";
                    resultDiv.style.color = "green";
                    this.reset();
                } else {
                    resultDiv.innerText = result.title ?? "Error occurred.";
                    resultDiv.style.color = "red";
                }
            } catch (error) {
                resultDiv.innerText = "Connection error.";
                resultDiv.style.color = "red";
            }
        });
    </script>
}