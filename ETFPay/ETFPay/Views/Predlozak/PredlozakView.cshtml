@model IEnumerable<ETFPay.Models.Predlozak>

@{
    ViewData["Title"] = "PREDLOSCI";
    var selectedTemplate = ViewBag.SelectedTemplate as ETFPay.Models.Predlozak;
}

<div class="hero">
    <div class="container mt-4">
        <div class="row">
            <div class="col-md-6">
                <h1 class="mb-4" style="font-size: 28px; font-weight: 700; color: #163f38;">PREDLOSCI</h1>

                @if (Model != null && Model.Any())
                {
                    <div class="mb-4">
                        <h5 class="text-muted mb-3" style="font-size: 12px; text-align: left;">Naziv</h5>
                        @foreach (var template in Model)
                        {
                            ViewBag.IsSelected = selectedTemplate?.Id == template.Id;
                            ViewBag.ActionName = "PredlozakView";
                            @await Html.PartialAsync("~/Views/Shared/_ListItem.cshtml", template)
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-4">
                        <p>Nema dostupnih predložaka. Kliknite na dugme ispod da dodate novi.</p>
                    </div>
                }

                <a asp-action="DodavanjePredlozaka" style="text-decoration: none;">
                    <button type="button" class="btn btn-success btn-lg" style="background-color: #2d8a6f; border: none; padding: 12px 30px; font-weight: 600; width: auto;">
                        KREIRAJ PREDLOZAK
                    </button>
                </a>
            </div>

            @if (selectedTemplate != null)
            {
                <div class="col-md-6">
                    @{
                        ViewBag.HeaderText = selectedTemplate.Naziv.ToUpper();
                    }
                    @await Html.PartialAsync("~/Views/Shared/_DetailCard.cshtml", selectedTemplate)

                    <div class="mt-4 text-end">
                        <a asp-action="Delete" asp-route-id="@selectedTemplate.Id" style="text-decoration: none;">
                            <button type="button" class="btn btn-success" style="background-color: #2d8a6f; border: none; padding: 10px 25px; font-weight: 600;">
                                OBRISI
                            </button>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .btn-success {
        background-color: #2d8a6f !important;
        border-color: #2d8a6f !important;
    }

    .btn-success:hover {
        background-color: #1f5f4f !important;
        border-color: #1f5f4f !important;
    }

    .alert-success {
        background-color: #2d8a6f !important;
        border-color: #2d8a6f !important;
    }
</style>
