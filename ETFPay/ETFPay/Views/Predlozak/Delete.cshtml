@model ETFPay.Models.Predlozak

@{
    ViewData["Title"] = "Delete";
}

<div class="hero">
    <div class="container mt-5">
        <div class="modal" style="display: block; background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header" style="background-color: #1f6b60; color: white; border: none;">
                        <h5 class="modal-title">Confirm Delete</h5>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete <strong>@Model.Naziv</strong>?</p>
                        <p class="text-muted mb-0">This action cannot be undone.</p>
                    </div>
                    <div class="modal-footer">
                        @{
                            string backAction = Model.Pretplata ? "PretplataView" : "PredlozakView";
                        }
                        <a asp-action="@backAction" class="btn btn-secondary">Cancel</a>
                        <form asp-action="Delete" method="post" style="display: inline;">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
