@model ETFPay.Models.Predlozak

@{
    string formAction = ViewData["FormAction"] as string ?? "DodavanjePredlozaka";
    string pageTitle = ViewData["PageTitle"] as string ?? "Add Template";
    string submitButtonText = ViewData["SubmitButtonText"] as string ?? "ADD TEMPLATE";
    bool showPeriodSection = (bool)(ViewData["ShowPeriod"] ?? false);
}

<div class="hero">
    <div class="container">
        <h1 class="text-center mb-5" style="font-weight: 700; font-size: 36px;">@pageTitle</h1>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <h4>Validation errors:</h4>
                        <ul>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <form asp-action="@formAction" method="post">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="row">
                        <!-- Left Column -->
                        <div class="col-md-6">
                            <div class="mb-4">
                                <input asp-for="Naziv" class="form-control" placeholder="Name:" style="border-radius: 8px; border: 1px solid #ccc; padding: 12px; font-size: 14px; color: #999;" />
                                <span asp-validation-for="Naziv" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <input asp-for="SvrhaUplate" class="form-control" placeholder="Payment purpose:" style="border-radius: 8px; border: 1px solid #ccc; padding: 12px; font-size: 14px; color: #999;" />
                                <span asp-validation-for="SvrhaUplate" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <input asp-for="Adresa" class="form-control" placeholder="Address:" style="border-radius: 8px; border: 1px solid #ccc; padding: 12px; font-size: 14px; color: #999;" />
                                <span asp-validation-for="Adresa" class="text-danger"></span>
                            </div>

                            @if (showPeriodSection)
                            {
                                <div class="mb-4">
                                    <input asp-for="Iznos" class="form-control" placeholder="Amount:" style="border-radius: 8px; border: 1px solid #ccc; padding: 12px; font-size: 14px; color: #999;" />
                                    <span asp-validation-for="Iznos" class="text-danger"></span>
                                </div>
                            }
                        </div>

                        <!-- Right Column -->
                        <div class="col-md-6">
                            <div class="mb-4">
                                <input asp-for="Primaoc" class="form-control" placeholder="Recipient Account Number:" style="border-radius: 8px; border: 1px solid #ccc; padding: 12px; font-size: 14px; color: #999;" />
                                <span asp-validation-for="Primaoc" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <input asp-for="Grad" class="form-control" placeholder="City:" style="border-radius: 8px; border: 1px solid #ccc; padding: 12px; font-size: 14px; color: #999;" />
                                <span asp-validation-for="Grad" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    @if (showPeriodSection)
                    {
                        <!-- Period Section (for subscriptions) -->
                        <div class="row mt-4 mb-5 align-items-center">
                            <div class="col-md-6">
                                <label style="font-weight: 600; color: #333; font-size: 14px;">EXECUTE SUBSCRIPTION EVERY:</label>
                            </div>
                            <div class="col-md-6">
                                <select asp-for="Period" class="form-control" style="border-radius: 8px; border: 1px solid #ccc; padding: 12px; font-size: 14px;">
                                    <option value="">-- Select Period --</option>
                                    <option value="0">Daily</option>
                                    <option value="1">Weekly</option>
                                    <option value="2">Monthly</option>
                                    <option value="3">Yearly</option>
                                </select>
                                <span asp-validation-for="Period" class="text-danger"></span>
                            </div>
                        </div>
                    }

                    <!-- Submit Button -->
                    <div class="form-group" @if (showPeriodSection) { <text>mt-4</text> } else { <text>mt-5</text> }>
                        <input type="submit" value="@submitButtonText" class="btn" style="background-color: #1f6b60; color: white; border: none; padding: 12px 40px; font-weight: 600; border-radius: 8px; font-size: 14px;" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
