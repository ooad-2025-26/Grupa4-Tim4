@model IEnumerable<ETFPay.Models.Predlozak>

@{
    ViewData["Title"] = "UPRAVLJANJE PRETPLATAMA";
    var selectedSubscription = ViewBag.SelectedSubscription as ETFPay.Models.Predlozak;
}

<div class="hero">
    <div class="container mt-4">
        <div class="row">
            <div class="col-md-6">
                <h1 class="mb-4" style="font-size: 28px; font-weight: 700; color: #163f38;">Subscriptions</h1>

                @if (Model != null && Model.Any())
                {
                    <div class="mb-4">
                        <h5 class="text-muted mb-3" style="font-size: 12px; text-align: left;">Name</h5>
                        @foreach (var subscription in Model)
                        {
                            ViewBag.IsSelected = selectedSubscription?.Id == subscription.Id;
                            ViewBag.ActionName = "PretplataView";
                            @await Html.PartialAsync("~/Views/Shared/_ListItem.cshtml", subscription)
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-4">
                        <p>You have no active subscriptions. Click on the button below to add one.</p>
                    </div>
                }

                <a asp-action="DodavanjePretplate" style="text-decoration: none;">
                    <button type="button" class="btn btn-success btn-lg" style="background-color: #2d8a6f; border: none; padding: 12px 30px; font-weight: 600; width: auto;">
                        Add a subscription
                    </button>
                </a>
            </div>

            @if (selectedSubscription != null)
            {
                <div class="col-md-6">
                    @{
                        ViewBag.HeaderText = selectedSubscription.Naziv.ToUpper();
                    }
                    @await Html.PartialAsync("~/Views/Shared/_DetailCard.cshtml", selectedSubscription)

                    <div class="mt-4 text-end">
                        <a asp-action="Delete" asp-route-id="@selectedSubscription.Id" style="text-decoration: none;">
                            <button type="button" class="btn btn-success" style="background-color: #2d8a6f; border: none; padding: 10px 25px; font-weight: 600;">
                                Delete
                            </button>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .btn-success {
        background-color: #2d8a6f !important;
        border-color: #2d8a6f !important;
    }

    .btn-success:hover {
        background-color: #1f5f4f !important;
        border-color: #1f5f4f !important;
    }

    .alert-success {
        background-color: #2d8a6f !important;
        border-color: #2d8a6f !important;
    }
</style>