@model List<ETFPay.Models.Kurs>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Valute";
}

<style>
    body { background-color: #f4f7f6; }
    .zrequests { display: flex; align-items:top; gap: 40px; padding: 30px; }
    .z-left { width: 45%; }
    .z-right { width: 45%; }
    .z-title { font-size: 32px; font-weight: 800; margin-bottom: 18px; text-transform: uppercase; }
    .list-header { display: flex; justify-content: space-between; margin-bottom: 10px; font-weight: 600; color: #666; }
    .kursevi { padding-right: 6px; border-radius: 10px; max-height: 450px; overflow: auto; }
    .kurs-item { display: flex; justify-content: space-between; align-items: center; background: #e9e9e9; padding: 14px; margin: 8px 0; border-radius: 10px; border: none; font-size: inherit; text-align: left; width: 100%; }
    .kurs-item.baza { background: #1f7a66; color: white; }
    .kurs-info { display: flex; gap: 20px; align-items: center; }
    .kurs-code { font-weight: 800; min-width: 50px; }
    .kurs-name { color: #444; }
    #bazni-kurs-name {color: #fff; }
    .kurs-item.baza .kurs-name { color: #e0e0e0; }
    .kurs-value { font-weight: 700; }

    .konverzije-kontejner { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; }
    .kurs-input-group { flex: 1; display: flex; flex-direction: column; gap: 10px; }
    .kurs-input-group input { padding: 12px; border-radius: 10px; border: 1px solid #ccc; font-size: 16px; width: 100%; box-sizing: border-box; }
    .kurs-input-group input.code-input { font-weight: 800; text-transform: uppercase; }
    .kurs-input-group input.readonly-input { background-color: #e9e9e9; border: none; font-weight: bold; }
    .jednako { font-size: 32px; font-weight: 800; color: #1f7a66; }
    .search-input { width: 100%; padding: 14px 20px; border-radius: 30px; border: 1px solid #ccc; font-size: 16px; box-sizing: border-box; }
    
    .btn-submit { background: #1f7a66; color: white; border: none; padding: 10px 20px; border-radius: 10px; font-weight: 700; width: 100%; cursor: pointer; margin-bottom: 25px; }
    .btn-submit:hover { background: #175a4b; }
</style>

<div class="hero">
    <div class="container">
        <div class="zrequests">
            <div class="z-left">
                <div class="z-title">Latest rates</div>
                <div class="list-header">
                    <div>Abbreviation/Name</div>
                    <div>Rate</div>
                </div>

                <div class="kursevi" id="listaValuta">
                    <div class="kurs-item baza">
                        <div class="kurs-info">
                            <span class="kurs-code">BAM</span>
                            <span id="bazni-kurs-name">Bosnian mark</span>
                        </div>
                        <div class="kurs-value">1</div>
                    </div>

                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            string puniNaziv = (ViewBag.NaziviValuta != null && ViewBag.NaziviValuta.ContainsKey(item.CiljanaValuta.ToUpper())) 
                                                   ? ViewBag.NaziviValuta[item.CiljanaValuta.ToUpper()] 
                                                   : "";
                            <div class="kurs-item kurs-row" data-quote="@item.CiljanaValuta" data-name="@puniNaziv.ToLower()">
                                <div class="kurs-info">
                                    <span class="kurs-code">@item.CiljanaValuta</span>
                                    <span class="kurs-name">@puniNaziv</span>
                                </div>
                                <div class="kurs-value">@item.KursValute.ToString("F5")</div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="z-right">
                <div class="z-title">Currency conversion</div>
                
                <form method="get" action="/Currencies">
                    
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("KonverzijaGreska"))
                    {
                        <div class="alert alert-danger p-2 small mb-3" role="alert">
                            @ViewData.ModelState["KonverzijaGreska"].Errors.FirstOrDefault()?.ErrorMessage
                        </div>
                    }

                    <div class="konverzije-kontejner">
                        <div class="kurs-input-group">
                            <input type="text" name="iz" class="code-input" value="@ViewBag.Iz" required placeholder="From" />
                            <input type="number" name="iznos" value="@ViewBag.Iznos" step="any" min="0.00001" required />
                        </div>

                        <div class="jednako">=</div>

                        <div class="kurs-input-group">
                            <input type="text" name="u" class="code-input" value="@ViewBag.U" required placeholder="To" />
                            <input type="text" class="readonly-input" readonly value="@ViewBag.Rezultat" placeholder="" />
                        </div>
                    </div>
                    
                    <button type="submit" class="btn-submit">CONVERT</button>
                </form>

                <div class="z-title" style="font-size: 28px;">Pretraga</div>

                    <form method="get" action="/Currencies">
                        <input type="hidden" name="iz" value="@ViewBag.Iz" />
                        <input type="hidden" name="u" value="@ViewBag.U" />
                        <input type="hidden" name="iznos" value="@ViewBag.Iznos" />

                        <div style="margin-bottom: 15px;">
                            <input type="text" name="pretraga" class="search-input" placeholder="Enter a currency..." value="@ViewBag.Pretraga" />
                        </div>
                    </form>
                    <div class="list-header">
                        <div>Abbreviation/Name</div>
                        <div>Rate</div>
                    </div>
                    <div class="list-header" style="padding: 0 10px; margin-top: 15px;">
                        @if (ViewBag.RezultatPretrage is ETFPay.Models.Kurs res)
                        {
                            <div style="font-size: 18px; color: black;">@res.CiljanaValuta</div>
                            <div style="font-size: 18px; color: black;">@res.KursValute.ToString("F5")</div>
                        }
                        else
                        {
                            <div>---</div>
                            <div>-----</div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(ViewBag.Pretraga) && ViewBag.RezultatPretrage == null)
                    {
                        <div style="padding: 5px 10px; color: #cc0000; font-size: 14px;">
                            Currency not found.
                        </div>
                    }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}