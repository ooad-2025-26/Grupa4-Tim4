{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "https",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net10.0/ETFPay.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "launchBrowser": {
        "enabled": true,
        "args": "${auto-detect-url}"
      },
      "launchSettingsFilePath": "${workspaceFolder}/Properties/launchSettings.json",
      "launchSettingsProfile": "https"
    },
    {
      "name": "http",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net10.0/ETFPay.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "launchBrowser": {
        "enabled": true,
        "args": "${auto-detect-url}"
      },
      "launchSettingsFilePath": "${workspaceFolder}/Properties/launchSettings.json",
      "launchSettingsProfile": "http"
    }
  ]
}
